start: begin_patch hunk+ end_patch
begin_patch: "*** Begin Patch" LF
end_patch: "*** End Patch" LF?

hunk: update_hunk
update_hunk: "¶" filename ("#" file_hash)? LF block*

filename: /([^\s#]+)/
file_hash: /[0-9A-F]{3}/

block: anchor ":" delete_suffix? LF payload*
delete_suffix: "-"
payload: literal_payload | repeat_payload
literal_payload: "+" /[^\n]*/ LF
repeat_payload: "^" range LF

anchor: range | "BOF" | "EOF"
range: LID "-" LID

LID: /[1-9]\d*/

%import common.LF
